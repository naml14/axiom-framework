{
  "name": "axiom",
  "version": "0.0.1",
  "description": "Web framework with two-phase rendering",
  "type": "module",
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "demo:build": "bun build demo/app.ts --outfile demo/app.js --target browser",
    "run:demo": "bun run demo/server.ts --no-build",
    "demo": "bun run demo:build && bun run run:demo",
    "demo:watch": "bun run demo/server.ts --watch"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "happy-dom": "^20.8.9"
  }
}
