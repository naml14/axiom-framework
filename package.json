{
  "name": "axiom-framework",
  "version": "0.2.5",
  "description": "Web framework with two-phase rendering. All calculations happen in memory. The hot path is pure arithmetic. Zero DOM reads.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=22.0.0",
    "bun": ">=1.0.0"
  },
  "scripts": {
    "build": "bunx tsc --project tsconfig.build.json",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test",
    "prepublishOnly": "bun run typecheck && bun test && bun run build",
    "demo:build": "bun run build && bun build demo/app.ts --outfile demo/app.js --target browser",
    "run:demo": "bun run demo/server.ts --no-build",
    "demo": "bun run demo:build && bun run run:demo",
    "demo:watch": "bun run demo/server.ts --watch"
  },
  "keywords": [
    "framework",
    "signals",
    "reactive",
    "layout",
    "performance",
    "dom",
    "two-phase rendering",
    "masonry",
    "flex",
    "typescript"
  ],
  "author": "Nelson Andrés Mora López <na2003ml.am@gmail.com>",
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/naml14/axiom-framework.git"
  },
  "bugs": {
    "url": "https://github.com/naml14/axiom-framework/issues"
  },
  "homepage": "https://github.com/naml14/axiom-framework#readme",
  "devDependencies": {
    "@types/bun": "1.3.11",
    "happy-dom": "^20.8.9",
    "typescript": "^6.0.2"
  }
}
