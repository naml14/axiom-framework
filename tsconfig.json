{
  "compilerOptions": {
     // Environment setup & latest features
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "jsxImportSource": "axiom-framework",
    "allowJs": true,
    "types": ["bun", "node"],

    // Bundler mode
    "moduleResolution": "bundler",
    "paths": {
      "axiom-framework": ["./src/index.ts"],
      "axiom-framework/jsx-runtime": ["./src/jsx-runtime.ts"],
      "axiom-framework/jsx-dev-runtime": ["./src/jsx-dev-runtime.ts"],
      "axiom-framework/jsx-types": ["./src/jsx.d.ts"]
    },
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    // Some stricter flags (disabled by default)
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "tests/**/*.ts", "tests/types/**/*.test-d.ts", "demo/**/*.ts", "demo/**/*.tsx", "scripts/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
