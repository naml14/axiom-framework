# ============================================================
# Axiom — .gitignore
# ============================================================

# --- Build Output ---
demo/app.js
dist/

# --- Dependencies ---
node_modules/
bun.lock

# --- Editor / IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Bun ---
.bun/

# --- TypeScript ---
*.tsbuildinfo

# --- Testing ---
coverage/

# --- Debug ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Environment ---
.env
.env.local
.env.*.local

# --- Temporary ---
*.tmp
*.temp
.cache/

# --- Misc ---
*.bak
*.backup
*.old
*.orig
*.rej
pretext-main/
