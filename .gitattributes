# Normalize line endings to LF in the repository
# Windows checkouts will still use CRLF locally if core.autocrlf=true
* text=auto eol=lf

# bun.lock is text (YAML-like), must be LF
bun.lock text eol=lf

# Binary files — never modify line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.zip binary
